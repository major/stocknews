{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>major/renovate-config"],
  "constraints": {
    "go": "1.26"
  },
  "packageRules": [
    {
      "matchManagers": ["gomod"],
      "matchDepNames": ["go"],
      "matchDepTypes": ["golang"],
      "rangeStrategy": "bump"
    }
  ]
}
